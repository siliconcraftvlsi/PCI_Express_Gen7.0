      <spirit:value spirit:format="long">16</spirit:value>
    </spirit:parameter>
    <spirit:parameter>
      <spirit:name>DATA_W</spirit:name>
      <spirit:displayName>Internal Data Width (bits)</spirit:displayName>
      <spirit:value spirit:format="long">256</spirit:value>
    </spirit:parameter>
    <spirit:parameter>
      <spirit:name>EN_DMA</spirit:name>
      <spirit:displayName>Enable DMA Engine</spirit:displayName>
      <spirit:value spirit:format="bool">true</spirit:value>
    </spirit:parameter>
    <spirit:parameter>
      <spirit:name>DMA_CHANNELS</spirit:name>
      <spirit:displayName>Number of DMA Channels</spirit:displayName>
      <spirit:value spirit:format="long">4</spirit:value>
    </spirit:parameter>
    <spirit:parameter>
      <spirit:name>VENDOR_ID</spirit:name>
      <spirit:displayName>PCIe Vendor ID</spirit:displayName>
      <spirit:value spirit:format="string">0xCAFE</spirit:value>
    </spirit:parameter>
    <spirit:parameter>
      <spirit:name>DEVICE_ID</spirit:name>
      <spirit:displayName>PCIe Device ID</spirit:displayName>
      <spirit:value spirit:format="string">0x0001</spirit:value>
    </spirit:parameter>
  </spirit:parameters>

